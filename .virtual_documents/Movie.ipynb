import ast

#helper function
def convert(text):
    L=[]
    for i in ast.literal_eval(text):
        L.append(i['name'])
    return L


movies['genres']=movies['genres'].apply(convert)


movies.head()


movies['keywords']=movies['keywords'].apply(convert)


movies.head()


movies['cast'][0]


def convert3(text):
    L=[]
    counter=0
    for i in ast.literal_eval(text):
        if counter != 3:
            L.append(i['name'])
            counter+=1
        else:
            break
    return L


movies['cast'] = movies['cast'].apply(convert3)


movies.head()


movies['crew'][0]


